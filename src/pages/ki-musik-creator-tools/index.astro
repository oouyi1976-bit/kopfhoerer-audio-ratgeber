---
import BaseLayout from "@components/Layout/BaseLayout.astro";
import CreatorOfferCard from "@components/CreatorOfferCard.astro";
import { creatorOffers } from "@data/creatorOffers";
---

<BaseLayout
  title="KI-Musik, Musikvideos & Creator-Tools"
  description="Digitale Kurse und Tools für Creator, die Musik, Musikvideos und Content mit KI erstellen oder vermarkten möchten."
>
  <section class="dark-section overflow-hidden py-14 sm:py-20">
    <div class="page-shell grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr]">
      <div>
        <p class="inline-flex rounded-full border border-violet-300/30 bg-violet-300/10 px-4 py-2 text-sm font-bold text-violet-100">
          Creator-Tools
        </p>
        <h1 class="mt-6 max-w-4xl text-4xl font-black leading-tight text-white sm:text-5xl">
          KI-Musik, Musikvideos & Creator-Tools
        </h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">
          Digitale Kurse und Tools für alle, die Musik, Videos und Content mit KI erstellen oder vermarkten möchten.
        </p>
        <p class="mt-5 max-w-3xl leading-7 text-slate-400">
          Hier findest du digitale Angebote getrennt von Kopfhörern und Lautsprechern. Der Fokus liegt auf kreativen Workflows, Musikproduktion, Videoideen und Content-Planung.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="#angebote" class="rounded-full bg-violet-300 px-6 py-3 text-center text-sm font-black text-ink shadow-glow transition hover:-translate-y-0.5">
            Angebote ansehen
          </a>
          <a href="/kopfhoerer/" class="rounded-full border border-white/15 px-6 py-3 text-center text-sm font-black text-white transition hover:bg-white/10">
            Kopfhörer vergleichen
          </a>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/10 shadow-glow">
        <img
          src="/creator-offer-images/hero-ki-musik-creator-tools.webp"
          alt="Modernes Musikstudio mit Laptop, Audio-Wellenform und Creator-Equipment"
          class="aspect-[16/10] h-full w-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="light-section bg-[#f4f8fb] py-14 sm:py-18">
    <div class="page-shell grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="text-sm font-black uppercase tracking-[0.18em] text-violet-700">Digital statt Hardware</p>
        <h2 class="mt-3 text-3xl font-black text-slate-950">Für wen diese Kategorie gedacht ist</h2>
        <p class="mt-4 leading-8 text-slate-700">
          Diese Auswahl richtet sich an Musiker, Video-Creator, Podcaster und Content-Macher, die KI als Werkzeug im kreativen Prozess ausprobieren möchten. Die Angebote können helfen, Ideen zu sortieren, Workflows kennenzulernen oder eigene Projekte strukturierter anzugehen.
        </p>
        <div class="mt-6 grid gap-3 text-sm font-black text-cyan-800">
          <a href="/bluetooth-lautsprecher/" class="rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-card transition hover:border-cyan-300 hover:text-violet-700">
            Zurück zu Bluetooth-Lautsprechern
          </a>
          <a href="/gaming-headsets/" class="rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-card transition hover:border-cyan-300 hover:text-violet-700">
            Gaming-Headsets ansehen
          </a>
        </div>
      </div>
      <div id="angebote" class="grid gap-6 md:grid-cols-2">
        {creatorOffers.map((offer) => <CreatorOfferCard offer={offer} />)}
      </div>
    </div>
  </section>

  <section class="light-section bg-white py-14 sm:py-18">
    <div class="page-shell">
      <div class="max-w-3xl">
        <p class="text-sm font-black uppercase tracking-[0.18em] text-cyan-700">Orientierung</p>
        <h2 class="mt-3 text-3xl font-black text-slate-950">Häufige Fragen zu KI-Musik und Creator-Tools</h2>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        <article class="rounded-2xl border border-slate-200 bg-[#f8fbfd] p-6">
          <h3 class="text-xl font-black text-slate-950">Was sind KI-Musik-Tools?</h3>
          <p class="mt-3 leading-7 text-slate-700">
            KI-Musik-Tools unterstützen bei Ideen, Sounds, Texten, Arrangements oder visuellen Konzepten. Sie ersetzen nicht automatisch Geschmack, Rechteprüfung oder saubere Produktion, können aber als kreativer Startpunkt interessant sein.
          </p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-[#f8fbfd] p-6">
          <h3 class="text-xl font-black text-slate-950">Für wen eignen sich KI-Musik-Kurse?</h3>
          <p class="mt-3 leading-7 text-slate-700">
            Sie eignen sich für Creator, Musiker und Selbstständige, die KI-Workflows lernen möchten. Besonders hilfreich kann das sein, wenn du eigene Musik, Videos oder Social-Content strukturierter planst.
          </p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-[#f8fbfd] p-6">
          <h3 class="text-xl font-black text-slate-950">Brauche ich Vorkenntnisse?</h3>
          <p class="mt-3 leading-7 text-slate-700">
            Das hängt vom jeweiligen Angebot ab. Prüfe vor dem Kauf die Detailseite, Inhalte und Voraussetzungen. Grundkenntnisse in Musik, Video oder Content-Erstellung helfen oft, sind aber nicht immer zwingend.
          </p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-[#f8fbfd] p-6">
          <h3 class="text-xl font-black text-slate-950">Warum gibt es digitale Angebote neben Kopfhörern?</h3>
          <p class="mt-3 leading-7 text-slate-700">
            KlangFinder bleibt eine Audio-Seite, erweitert den Blick aber auf kreative Nutzung: Wer Musik hört, aufnimmt oder veröffentlicht, interessiert sich oft auch für Tools, Kurse und Workflows rund um Studio und Content.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
