---
type Props = {
  title: string;
  description: string;
  href: string;
  topic: string;
  image: string;
};

const { title, description, href, topic, image } = Astro.props;
---

<a href={href} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-card transition hover:-translate-y-1 hover:border-violet-300">
  <div class="aspect-[4/3] bg-slate-100">
    <img src={image} alt={`${title} realistisches Ratgeberbild`} class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.035]" loading="lazy" />
  </div>
  <div class="p-6">
    <span class="text-xs font-black uppercase tracking-[0.18em] text-violet-700">{topic}</span>
    <h3 class="mt-4 text-xl font-black text-slate-950">{title}</h3>
    <p class="mt-3 text-sm leading-6 text-slate-600">{description}</p>
    <span class="mt-5 inline-flex text-sm font-black text-cyan-700">Weiterlesen</span>
  </div>
</a>
