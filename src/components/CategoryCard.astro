---
type Props = {
  title: string;
  description: string;
  href: string;
  label: string;
  image: string;
};

const { title, description, href, label, image } = Astro.props;
---

<a href={href} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-card transition hover:-translate-y-1 hover:border-cyan-300">
  <div class="aspect-[4/3] bg-slate-100">
    <img src={image} alt={`${title} realistisches Produktbild`} class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.035]" loading="lazy" />
  </div>
  <div class="p-5">
    <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-black uppercase tracking-[0.16em] text-slate-600">
      {label}
    </span>
    <h3 class="mt-5 text-xl font-black text-slate-950">{title}</h3>
    <p class="mt-3 text-sm leading-6 text-slate-600">{description}</p>
    <span class="mt-5 inline-flex text-sm font-black text-cyan-700 group-hover:text-violet-700">Ansehen</span>
  </div>
</a>
