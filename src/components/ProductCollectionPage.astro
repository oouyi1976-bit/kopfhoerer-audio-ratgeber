---
import ProductGrid from "./ProductGrid.astro";
import GuideCard from "./GuideCard.astro";
import { guides } from "@data/site";
import { productsForCollection } from "@data/audioProducts";

type Page = {
  eyebrow: string;
  title: string;
  description: string;
  intro: string;
  collection: string;
  image: string;
};

type Props = {
  page: Page;
};

const { page } = Astro.props;
const products = productsForCollection(page.collection);
const relatedGuides = guides.slice(0, 3);
---

<section class="dark-section py-14 sm:py-18">
  <div class="page-shell">
    <p class="inline-flex rounded-full border border-cyan-300/30 bg-cyan-300/10 px-4 py-2 text-sm font-bold text-cyan-100">
      {page.eyebrow}
    </p>
    <h1 class="mt-6 max-w-4xl text-4xl font-black leading-tight text-white sm:text-5xl">{page.title}</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">{page.description}</p>
    <div class="mt-8 grid gap-6 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
      <div>
        <div class="rounded-2xl border border-white/10 bg-white/10 px-5 py-4 text-sm leading-6 text-slate-200">
          Vergleiche beliebte Audio-Produkte und finde schneller das passende Zubehör für Musik, Gaming, Reisen oder Arbeit.
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/10 shadow-glow">
        <img src={page.image} alt={`${page.title} realistisches Kategorie-Bild`} class="aspect-[16/10] h-full w-full object-cover" loading="eager" />
      </div>
    </div>
  </div>
</section>

<section class="light-section bg-[#f4f8fb] py-12 sm:py-16">
  <div class="page-shell">
    <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <h2 class="text-3xl font-black text-slate-950">Worauf es hier ankommt</h2>
        <p class="mt-4 leading-8 text-slate-700">{page.intro}</p>
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-card">
          <h3 class="text-lg font-black text-slate-950">Schnellcheck</h3>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-700">
            <li>Keine Preise, keine Sterne und keine erfundenen Testurteile.</li>
            <li>Bild, Titel und Button führen bei verfügbaren Angeboten zum selben Ziel.</li>
            <li>Die Auswahl bleibt nach Einsatzbereich sortiert und gut scanbar.</li>
          </ul>
        </div>
      </div>
      <ProductGrid products={products} />
    </div>
  </div>
</section>

<section class="light-section bg-white py-12 sm:py-16">
  <div class="page-shell">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.18em] text-cyan-700">Weiterlesen</p>
        <h2 class="mt-2 text-3xl font-black text-slate-950">Ratgeber für bessere Kaufentscheidungen</h2>
      </div>
      <a href="/ratgeber/" class="text-sm font-black text-cyan-700 hover:text-violet-700">Alle Ratgeber</a>
    </div>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {relatedGuides.map((guide) => <GuideCard {...guide} />)}
    </div>
  </div>
</section>
